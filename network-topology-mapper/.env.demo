# =============================================================================
# NTS Demo Environment
#
# Used with: docker compose -f docker-compose.yml -f docker-compose.demo.yml
#            --env-file .env.demo up -d
#
# Demo subnet: 172.20.0.0/24 (fixed via IPAM in docker-compose.demo.yml)
# =============================================================================

# Neo4j (Docker mode — communicate by container name)
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme
NEO4J_DATABASE=neo4j

# Redis (Docker mode)
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=

# SQLite
SQLITE_PATH=./data/mapper.db

# Scanning — target the fixed demo subnet
SCAN_DEFAULT_RANGE=172.20.0.0/24
SCAN_RATE_LIMIT=1000
SCAN_PASSIVE_INTERFACE=eth0
ENABLE_ACTIVE_SCAN=true
ENABLE_PASSIVE_SCAN=false
ENABLE_SNMP_SCAN=true

# SNMP — demo snmp-device responds to community "public"
SNMP_COMMUNITY=public
SNMP_VERSION=2c
SNMP_TIMEOUT=5
SNMP_RETRIES=3
SNMP_PORT=161

# SSH — no real credentials needed for demo (file-server won't be config-pulled)
SSH_USERNAME=
SSH_PASSWORD=
SSH_TIMEOUT=30

# Claude API (optional for demo)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# App
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=false
LOG_LEVEL=INFO
AGENT_MODE=alert

# WebSocket
WS_HEARTBEAT_INTERVAL=30
WS_MAX_CONNECTIONS=100

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
