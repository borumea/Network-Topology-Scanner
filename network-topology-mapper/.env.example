# ============================================================================
# NETWORK TOPOLOGY MAPPER - ENVIRONMENT CONFIGURATION
# ============================================================================
# Copy this file to .env and update with your values
# Never commit .env with real credentials!

# ============================================================================
# REDIS CONFIGURATION
# ============================================================================
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
REDIS_MAX_CONNECTIONS=50

# ============================================================================
# SQLITE CONFIGURATION
# ============================================================================
SQLITE_PATH=./data/mapper.db

# ============================================================================
# NETWORK SCANNING CONFIGURATION
# ============================================================================
# Default network range to scan (CIDR notation)
SCAN_DEFAULT_RANGE=192.168.0.0/16

# Scan rate limit (packets per second)
SCAN_RATE_LIMIT=1000

# Network interface for passive scanning
SCAN_PASSIVE_INTERFACE=eth0

# Enable/disable scan types
ENABLE_ACTIVE_SCAN=true
ENABLE_PASSIVE_SCAN=true
ENABLE_SNMP_SCAN=true

# ============================================================================
# SNMP CONFIGURATION
# ============================================================================
SNMP_COMMUNITY=public
SNMP_VERSION=2c
SNMP_TIMEOUT=5
SNMP_RETRIES=3
SNMP_PORT=161

# ============================================================================
# SSH/DEVICE CONFIGURATION (for config retrieval)
# ============================================================================
SSH_USERNAME=admin
SSH_PASSWORD=
SSH_KEY_PATH=/path/to/ssh/key
SSH_TIMEOUT=30

# ============================================================================
# ANTHROPIC CLAUDE API (for AI-powered reports)
# ============================================================================
ANTHROPIC_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-sonnet-4-5-20250929
CLAUDE_MAX_TOKENS=4000
CLAUDE_TEMPERATURE=0.7

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================
# Server settings
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=false
APP_ENV=production

# WebSocket settings
WS_HEARTBEAT_INTERVAL=30
WS_MAX_CONNECTIONS=100
WS_TIMEOUT=300

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=/var/log/network-mapper/app.log

# ============================================================================
# CELERY CONFIGURATION (Background Tasks)
# ============================================================================
# Celery broker and result backend
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Task schedules (cron expressions)
SCHEDULE_FULL_SCAN=0 */6 * * *         # Every 6 hours
SCHEDULE_SNMP_POLL=*/30 * * * *        # Every 30 minutes
SCHEDULE_SNAPSHOT=0 0 * * *            # Daily at midnight
SCHEDULE_ANOMALY_DETECTION=*/15 * * * * # Every 15 minutes

# ============================================================================
# AGENT MODE
# ============================================================================
# Options: alert | interactive | autonomous
# - alert: Only generates alerts, waits for user action
# - interactive: Suggests actions, asks for confirmation
# - autonomous: Automatically takes remediation actions
AGENT_MODE=alert

# ============================================================================
# SECURITY CONFIGURATION
# ============================================================================
# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# API rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# JWT secret (if authentication is enabled)
JWT_SECRET=your-secret-key-here
JWT_EXPIRATION=3600

# ============================================================================
# FRONTEND CONFIGURATION
# ============================================================================
# API and WebSocket URLs for frontend
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws

# Enable mock data for development
VITE_ENABLE_MOCK_DATA=false

# Feature flags
VITE_ENABLE_AI_REPORTS=true
VITE_ENABLE_SIMULATION=true
VITE_ENABLE_EXPORT=true

# ============================================================================
# DATA RETENTION
# ============================================================================
# Days to keep historical data
RETENTION_ALERTS_DAYS=90
RETENTION_SCANS_DAYS=30
RETENTION_SNAPSHOTS_DAYS=365

# ============================================================================
# ADVANCED SETTINGS
# ============================================================================
# Maximum devices to display in graph
MAX_GRAPH_DEVICES=1000

# Graph analysis batch size
GRAPH_ANALYSIS_BATCH_SIZE=100

# Cache TTL (seconds)
CACHE_TTL_TOPOLOGY=60
CACHE_TTL_DEVICE=300
CACHE_TTL_SCAN=600

# Database connection pool size
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
