# =============================================================================
# NTS — Dockerless / Bare-Metal Configuration
# =============================================================================
# For running NTS directly on your machine (no Docker).
# Copy to .env:  cp .env.dockerless .env
#
# Prerequisites:
#   - nmap installed and in PATH
#   - Python 3.11+, Node.js 18+
#   - (Optional) Redis on localhost:6379
#   - (Optional) Npcap for passive scanning on Windows
# =============================================================================

# Redis — optional, app works without it (no pubsub caching)
REDIS_URL=redis://localhost:6379/0

# SQLite — local file, no setup needed
SQLITE_PATH=./data/mapper.db

# Scanning — set this to YOUR network's subnet
SCAN_DEFAULT_RANGE=192.168.1.0/24
SCAN_RATE_LIMIT=500
SCAN_PASSIVE_INTERFACE=

# Scan phase toggles
ENABLE_ACTIVE_SCAN=true
ENABLE_PASSIVE_SCAN=false
ENABLE_SNMP_SCAN=true

# SNMP
SNMP_COMMUNITY=public
SNMP_VERSION=2c

# SSH — leave blank unless you have managed switches/routers
SSH_USERNAME=
SSH_PASSWORD=

# Claude API — optional, for AI-powered resilience reports
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-5-20250929

# App
APP_HOST=127.0.0.1
APP_PORT=8000
LOG_LEVEL=INFO
AGENT_MODE=alert

# WebSocket
WS_HEARTBEAT_INTERVAL=30

# Scheduled scanning — 0 = disabled (manual scans only)
SCAN_INTERVAL_MINUTES=0
